{
  "name": "dawka",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,worker -c blue,green \"npm run dev:web\" \"npm run dev:worker\"",
    "dev:web": "vite",
    "dev:worker": "wrangler dev",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/src/tsconfig.sw.json",
    "db:migrate:local": "wrangler d1 migrations apply dawka --local",
    "db:migrate:remote": "wrangler d1 migrations apply dawka --remote",
    "vapid:generate": "node -e \"import('webpush-webcrypto').then(async m => { const k = await m.ApplicationServerKeys.generate(); console.log(JSON.stringify(await k.toJSON(), null, 2)); })\""
  },
  "dependencies": {
    "hono": "^4.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "webpush-webcrypto": "^1.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.90.0"
  }
}
